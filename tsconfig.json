{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*",
      ],
      "@/2heroes/*": [
        "./app/2heroes/*",
      ],
      "@/about*/": [
        "./app/about/*",
      ],
      "@/components/*": [
        "./app/components/*",
      ],
      "@/contact/*": [
        "./app/contact/*",
      ],
      "@/lib/*": [
        "./app/lib/*",
      ],
      "@/links/*": [
        "./app/links/*",
      ],
      "@/events/*": [
        "./app/events/*",
      ],
      "@/products/*": [
        "./app/products/*",
      ],
      "@/style/*": [
        "./app/style/*",
      ],
      
    },
    "target": "ES2017"
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
